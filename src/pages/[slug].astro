---
import type { GetStaticPaths } from "astro";
import Base from "../layouts/Base.astro";
import EmbedCode from "../components/EmbedCode.astro";
import RankBadge from "../components/RankBadge.astro";
import {
  rankedUniversities,
  rankProfile,
  ordinal,
  scopeSuffix,
  type University,
  type BestRank,
} from "../lib/rankings";
import { href } from "../lib/paths";

export const getStaticPaths = (() => {
  return rankedUniversities().map((e) => ({
    params: { slug: e.slug },
    props: { university: e.university, slug: e.slug, best: e.best },
  }));
}) satisfies GetStaticPaths;

interface Props {
  university: University;
  slug: string;
  best: BestRank;
}

const { university, slug, best } = Astro.props;
const profile = rankProfile(university);
const place = university.city
  ? `${university.city}, ${university.country}`
  : university.country;
const claim = ordinal(best.rank);
const claimScope = scopeSuffix(best.ranking);
---

<Base
  title={`${university.name} — World ranking | The World University Index`}
  description={`${university.name} is ranked ${claim} in the world${claimScope}. Source: ${best.ranking.name} ${best.ranking.edition}.`}
>
  <article class="profile">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={href("/")}>The Index</a>
        <span aria-hidden="true">/</span>
        <span>{university.shortName ?? university.name}</span>
      </nav>

      <header class="masthead-uni">
        <p class="eyebrow">{place}</p>
        <h1 class="masthead-uni__name" style={`view-transition-name: inst-${slug}`}>
          {university.name}
        </h1>
      </header>

      <section class="headline" aria-labelledby="headline-claim">
        <p class="headline__label">Ranked in the world</p>
        <p class="headline__figure">
          <RankBadge rank={best.rank} large />
        </p>
        <p class="headline__claim" id="headline-claim">
          {university.name} is ranked <strong>{claim} in the world{claimScope}</strong>.
        </p>
        <p class="headline__source">
          Source:{" "}
          <a href={best.ranking.url} rel="external">
            {best.ranking.name}, {best.ranking.edition}
          </a>
        </p>
      </section>

      <section class="full" aria-labelledby="full-heading">
        <h2 id="full-heading" class="full__heading">Full ranking profile</h2>
        <p class="full__intro">
          {university.name}'s placement across the international ranking systems recorded
          by the Index. The headline figure above is the strongest of these.
        </p>
        <table class="profile-table">
          <thead>
            <tr>
              <th scope="col">Ranking</th>
              <th scope="col">Publisher</th>
              <th scope="col" class="num">World rank</th>
            </tr>
          </thead>
          <tbody>
            {
              profile.map((p) => (
                <tr class:list={[{ "is-best": p.ranking.id === best.ranking.id }]}>
                  <th scope="row" class="profile-table__name">
                    <a href={p.ranking.url} rel="external">
                      {p.ranking.shortName} {p.ranking.edition}
                    </a>
                    {p.ranking.id === best.ranking.id && <span class="tag">Headline</span>}
                    {p.ranking.scope && (
                      <span class="profile-table__scope">in the world for {p.ranking.scope}</span>
                    )}
                  </th>
                  <td>{p.ranking.publisher}</td>
                  <td class="num">
                    <RankBadge rank={p.rank} />
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="full__foot">
          Banded results are recorded at the lower bound of the band. For how the
          headline figure is selected, see the <a href={href("/methodology")}
            >methodology</a
          >.
        </p>
      </section>

      <EmbedCode university={university} slug={slug} />
    </div>
  </article>

  <style>
    .profile {
      padding-block: 2rem;
    }

    .crumbs {
      display: flex;
      gap: 0.6rem;
      align-items: center;
      font-size: 0.85rem;
      color: var(--ink-faint);
    }

    .crumbs a {
      color: var(--ink-soft);
      text-decoration: none;
    }

    .crumbs a:hover {
      color: var(--accent);
    }

    .masthead-uni {
      padding-block: 1.5rem 0.5rem;
      border-bottom: 2px solid var(--ink);
    }

    .masthead-uni__name {
      margin: 0.3rem 0 0;
      font-size: clamp(2.2rem, 1.2rem + 4.5vw, 3.6rem);
      max-width: 22ch;
    }

    .headline {
      display: grid;
      justify-items: start;
      gap: 0.4rem;
      padding-block: clamp(1.5rem, 0.5rem + 3vw, 3rem);
      border-bottom: 1px solid var(--rule);
    }

    .headline__label {
      margin: 0;
      font-family: var(--sans);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--ink-faint);
    }

    .headline__figure {
      margin: 0;
    }

    .headline__claim {
      margin: 0.4rem 0 0;
      font-family: var(--serif);
      font-size: clamp(1.3rem, 1rem + 1.5vw, 1.9rem);
      max-width: 28ch;
    }

    .headline__source {
      margin: 0.5rem 0 0;
      font-size: 0.9rem;
      color: var(--ink-faint);
    }

    .full {
      padding-block: 2.5rem;
    }

    .full__heading {
      margin: 0;
      font-size: 1.6rem;
    }

    .full__intro {
      margin: 0.5rem 0 1.5rem;
      max-width: 52ch;
      color: var(--ink-soft);
    }

    .profile-table {
      width: 100%;
      border-collapse: collapse;
    }

    .profile-table thead th {
      text-align: left;
      padding: 0 0.75rem 0.6rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      border-bottom: 1px solid var(--rule-strong);
    }

    .profile-table .num {
      text-align: right;
    }

    .profile-table tbody tr {
      border-bottom: 1px solid var(--rule);
    }

    .profile-table td,
    .profile-table th {
      padding: 0.85rem 0.75rem;
      vertical-align: baseline;
    }

    .profile-table__name {
      text-align: left;
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 500;
    }

    .profile-table__name a {
      color: var(--ink);
      text-decoration: none;
    }

    .profile-table__name a:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    .profile-table__scope {
      display: block;
      margin-top: 0.2rem;
      font-family: var(--sans);
      font-size: 0.82rem;
      font-weight: 400;
      color: var(--ink-faint);
    }

    .profile-table .num {
      font-size: 1.05rem;
    }

    .is-best {
      background: color-mix(in oklab, var(--gold) 12%, transparent);
    }

    .tag {
      display: inline-block;
      margin-left: 0.5rem;
      padding: 0.1rem 0.4rem;
      font-family: var(--sans);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--paper);
      background: var(--gold);
      border-radius: var(--radius);
      vertical-align: 0.15em;
    }

    .full__foot {
      margin-top: 1.5rem;
      font-size: 0.85rem;
      color: var(--ink-faint);
      max-width: 56ch;
    }
  </style>
</Base>
