---
import Base from "../layouts/Base.astro";
import RankBadge from "../components/RankBadge.astro";
import { rankedUniversities, regionFilters, regionOf } from "../lib/rankings";
import { universityHref } from "../lib/paths";

const entries = rankedUniversities();
const australian = entries.filter((e) => e.university.country === "Australia");
---

<Base
  title="The World University Index — 2026"
  description="An authoritative reference to the standing of the world's universities, reporting each institution's strongest verified placement across the major international rankings."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">2026 edition &middot; {entries.length} institutions</p>
      <h1 class="hero__title">The standing of the world's universities</h1>
      <p class="hero__lead">
        A consolidated reference drawn from the major international ranking
        systems. Each institution is listed at its strongest verified world
        placement, with {australian.length} Australian universities recorded in full.
      </p>
    </div>
  </section>

  <section class="container index">
    <div class="index__controls">
      <label class="search" for="filter">
        <span class="search__label">Find an institution</span>
        <input
          id="filter"
          type="search"
          name="filter"
          placeholder="Search by name or city…"
          autocomplete="off"
          spellcheck="false"
        />
      </label>
      <p class="index__count" id="count" role="status" aria-live="polite"></p>
    </div>

    <div class="index__filters">
      <div class="index__regions" role="group" aria-label="Filter by region">
        {
          regionFilters.map((f) => (
            <button
              type="button"
              class="region"
              data-region={f.key}
              aria-pressed={f.key === "all" ? "true" : "false"}
            >
              {f.label}
            </button>
          ))
        }
      </div>

      <div class="index__scope" role="group" aria-label="Ranking scope">
        <button type="button" class="region" data-scope="all" aria-pressed="true">
          All rankings
        </button>
        <button type="button" class="region" data-scope="overall" aria-pressed="false">
          Overall only
        </button>
      </div>
    </div>

    <table class="league">
      <caption class="visually-hidden">
        Universities ranked by their strongest world placement
      </caption>
      <thead>
        <tr>
          <th scope="col" class="league__rank-col">World rank</th>
          <th scope="col">Institution</th>
          <th scope="col" class="league__loc-col">Location</th>
        </tr>
      </thead>
      <tbody id="rows">
        {
          entries.map((e) => (
            <tr
              class="league__row"
              data-rank={e.best.rank}
              data-rank-overall={e.bestOverall?.rank}
              data-region={regionOf(e.university.country)}
              data-name={`${e.university.name} ${e.university.shortName ?? ""} ${e.university.city ?? ""} ${e.university.country} ${e.best.ranking.scope ?? ""}`.toLowerCase()}
            >
              <td class="league__rank">
                <RankBadge rank={e.best.rank} />
              </td>
              <th scope="row" class="league__inst">
                <a href={universityHref(e.slug)} data-vt-name={`inst-${e.slug}`}>
                  {e.university.name}
                </a>
              </th>
              <td class="league__loc">
                {e.university.city ? `${e.university.city}, ` : ""}
                {e.university.country}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    <p class="index__empty" id="empty" hidden>
      No institutions match that search.
    </p>
  </section>

  <script>
    const input = document.querySelector<HTMLInputElement>("#filter");
    const tbody = document.querySelector<HTMLTableSectionElement>("#rows");
    const rows = Array.from(
      document.querySelectorAll<HTMLTableRowElement>(".league__row"),
    );
    const regionButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-region]"),
    );
    const scopeButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-scope]"),
    );
    const count = document.querySelector<HTMLParagraphElement>("#count");
    const empty = document.querySelector<HTMLParagraphElement>("#empty");

    let region = "all";
    // "all" ranks each institution at its strongest placement across every
    // ranking family; "overall" restricts that to whole-of-institution rankings,
    // which changes each row's headline figure, the ordering, and which rows
    // qualify at all (a school listed only for a single subject drops out).
    let scope: "all" | "overall" = "all";

    // The rank an institution holds under the active scope, or null if it has no
    // placement in that scope.
    function rankOf(row: HTMLTableRowElement): number | null {
      const raw =
        scope === "overall" ? row.dataset.rankOverall : row.dataset.rank;
      return raw ? Number(raw) : null;
    }

    // Institutions sharing a world rank are genuinely tied — the server emits
    // them in a stable (alphabetical) order so the build is reproducible and the
    // no-JS view is sensible, but presenting that order every time would imply a
    // standing that doesn't exist. Sort by the active scope's rank and shuffle
    // each tied group so ties fall out at random; runs on load and whenever the
    // scope changes. Rows with no rank in this scope are left in place (the
    // search/filter pass hides them).
    function order() {
      if (!tbody) return;
      const ranked = rows
        .map((row) => ({ row, rank: rankOf(row) }))
        .filter((x): x is { row: HTMLTableRowElement; rank: number } => x.rank !== null)
        .toSorted((a, b) => a.rank - b.rank);
      for (let i = 0; i < ranked.length; ) {
        let j = i + 1;
        while (j < ranked.length && ranked[j].rank === ranked[i].rank) j += 1;
        const group = ranked.slice(i, j);
        for (let k = group.length - 1; k > 0; k -= 1) {
          const r = Math.floor(Math.random() * (k + 1));
          [group[k], group[r]] = [group[r], group[k]];
        }
        for (const { row } of group) tbody.appendChild(row);
        i = j;
      }
    }

    // Repaint each row's badge with its rank under the active scope.
    function paint() {
      for (const row of rows) {
        const num = row.querySelector<HTMLElement>(".badge__num");
        const rank = rankOf(row);
        if (num && rank !== null) num.textContent = String(rank);
      }
    }

    // Region buttons, the scope toggle and the search box compose: a row is
    // shown only when it has a rank in the active scope, sits in the active
    // region and matches the query.
    function apply() {
      const q = (input?.value ?? "").trim().toLowerCase();
      let shown = 0;
      let eligible = 0;
      for (const row of rows) {
        const inScope = rankOf(row) !== null;
        if (inScope) eligible += 1;
        const inRegion = region === "all" || row.dataset.region === region;
        const inSearch = q === "" || (row.dataset.name ?? "").includes(q);
        const match = inScope && inRegion && inSearch;
        row.hidden = !match;
        if (match) shown += 1;
      }
      if (empty) empty.hidden = shown !== 0;
      if (count) {
        count.textContent =
          shown === eligible
            ? `${eligible} institutions`
            : `${shown} of ${eligible} institutions`;
      }
    }

    for (const button of regionButtons) {
      button.addEventListener("click", () => {
        region = button.dataset.region ?? "all";
        for (const b of regionButtons)
          b.setAttribute("aria-pressed", b === button ? "true" : "false");
        apply();
      });
    }

    for (const button of scopeButtons) {
      button.addEventListener("click", () => {
        scope = button.dataset.scope === "overall" ? "overall" : "all";
        for (const b of scopeButtons)
          b.setAttribute("aria-pressed", b === button ? "true" : "false");
        order();
        paint();
        apply();
      });
    }

    if (input) input.addEventListener("input", apply);
    order();
    apply();

    // The index → institution morph is a cross-document view transition. Tagging
    // all rows with a view-transition-name up front makes Safari re-do transition
    // bookkeeping for every named element on each filter toggle, which beachballs
    // the tab. Instead, tag only the row being navigated away from, at the last
    // moment before the outgoing snapshot is taken.
    window.addEventListener("pageswap", (event) => {
      const swap = event as PageSwapEvent;
      const to = swap.activation?.entry.url;
      if (!swap.viewTransition || !to) return;
      for (const link of document.querySelectorAll<HTMLAnchorElement>(
        ".league__inst a",
      )) {
        if (link.href === to && link.dataset.vtName) {
          link.style.viewTransitionName = link.dataset.vtName;
          break;
        }
      }
    });
  </script>

  <style>
    .hero {
      padding-block: clamp(2.5rem, 1.5rem + 4vw, 4.5rem) 1.5rem;
    }

    .hero__title {
      margin: 0.4rem 0 0;
      font-size: clamp(2.4rem, 1.4rem + 4.5vw, 4rem);
      max-width: 18ch;
    }

    .hero__lead {
      margin: 1.25rem 0 0;
      max-width: 56ch;
      font-size: 1.15rem;
      color: var(--ink-soft);
    }

    .index {
      padding-bottom: 2rem;
    }

    .index__controls {
      display: flex;
      flex-wrap: wrap;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-top: 1.5rem;
      border-top: 2px solid var(--ink);
    }

    .search {
      display: grid;
      gap: 0.35rem;
      flex: 1 1 20rem;
    }

    .search__label {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
    }

    .search input {
      font: inherit;
      padding: 0.6rem 0.75rem;
      border: 1px solid var(--rule-strong);
      border-radius: var(--radius);
      background: var(--paper);
      color: var(--ink);
    }

    .search input:focus-visible {
      border-color: var(--accent);
      outline-offset: 0;
    }

    .index__count {
      margin: 0;
      font-size: 0.85rem;
      color: var(--ink-faint);
      font-variant-numeric: tabular-nums;
    }

    .index__filters {
      display: flex;
      flex-wrap: wrap;
      align-items: start;
      justify-content: space-between;
      gap: 0.75rem 1.5rem;
      margin-bottom: 1.25rem;
    }

    .index__regions,
    .index__scope {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .region {
      font: inherit;
      font-size: 0.85rem;
      padding: 0.4rem 0.85rem;
      color: var(--ink-soft);
      background: var(--paper);
      border: 1px solid var(--rule-strong);
      border-radius: 2rem;
      cursor: pointer;
    }

    .region:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .region:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .region[aria-pressed="true"] {
      color: var(--paper);
      background: var(--ink);
      border-color: var(--ink);
    }

    .league {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.98rem;
    }

    .league caption {
      text-align: left;
    }

    .league thead th {
      text-align: left;
      padding: 0 0.75rem 0.6rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      border-bottom: 1px solid var(--rule-strong);
    }

    .league__row {
      position: relative;
      border-bottom: 1px solid var(--rule);
    }

    .league__row:hover {
      background: color-mix(in oklab, var(--accent) 5%, transparent);
    }

    .league__row:hover .league__inst a {
      color: var(--accent);
      text-decoration: underline;
    }

    .league__row td,
    .league__row th {
      padding: 0.85rem 0.75rem;
      vertical-align: baseline;
    }

    .league__rank {
      width: 5.5rem;
      font-size: 1.2rem;
    }

    .league__inst {
      font-weight: 400;
      text-align: left;
    }

    .league__inst a {
      font-family: var(--serif);
      font-size: 1.15rem;
      color: var(--ink);
      text-decoration: none;
    }

    .league__inst a:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    /* The institution link stretches across the whole row so the entire row is
       a single click target. It is now the only link in the row, so there is no
       nested link to raise above it. */
    .league__inst a::after {
      content: "";
      position: absolute;
      inset: 0;
    }

    .league__loc {
      color: var(--ink-soft);
    }

    .index__empty {
      padding: 2rem 0.75rem;
      color: var(--ink-soft);
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    @media (max-width: 34rem) {
      .league__loc-col,
      .league__loc {
        display: none;
      }
    }
  </style>
</Base>
