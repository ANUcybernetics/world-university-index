---
import Base from "../layouts/Base.astro";
import RankBadge from "../components/RankBadge.astro";
import { rankedUniversities, regionFilters, regionOf } from "../lib/rankings";
import { universityHref } from "../lib/paths";

const entries = rankedUniversities();
const australian = entries.filter((e) => e.university.country === "Australia");
---

<Base
  title="The World University Index — 2026"
  description="An authoritative reference to the standing of the world's universities, reporting each institution's strongest verified placement across the major international rankings."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">2026 edition &middot; {entries.length} institutions</p>
      <h1 class="hero__title">The standing of the world's universities</h1>
      <p class="hero__lead">
        A consolidated reference drawn from the major international ranking
        systems. Each institution is listed at its strongest verified world
        placement, with {australian.length} Australian universities recorded in full.
      </p>
    </div>
  </section>

  <section class="container index">
    <div class="index__controls">
      <label class="search" for="filter">
        <span class="search__label">Find an institution</span>
        <input
          id="filter"
          type="search"
          name="filter"
          placeholder="Search by name or city…"
          autocomplete="off"
          spellcheck="false"
        />
      </label>
      <p class="index__count" id="count" role="status" aria-live="polite"></p>
    </div>

    <div class="index__regions" role="group" aria-label="Filter by region">
      {
        regionFilters.map((f) => (
          <button
            type="button"
            class="region"
            data-region={f.key}
            aria-pressed={f.key === "all" ? "true" : "false"}
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <table class="league">
      <caption class="visually-hidden">
        Universities ranked by their strongest world placement
      </caption>
      <thead>
        <tr>
          <th scope="col" class="league__rank-col">World rank</th>
          <th scope="col">Institution</th>
          <th scope="col" class="league__loc-col">Location</th>
        </tr>
      </thead>
      <tbody id="rows">
        {
          entries.map((e) => (
            <tr
              class="league__row"
              data-rank={e.best.rank}
              data-region={regionOf(e.university.country)}
              data-name={`${e.university.name} ${e.university.shortName ?? ""} ${e.university.city ?? ""} ${e.university.country} ${e.best.ranking.scope ?? ""}`.toLowerCase()}
            >
              <td class="league__rank">
                <RankBadge rank={e.best.rank} />
              </td>
              <th scope="row" class="league__inst">
                <a
                  href={universityHref(e.slug)}
                  style={`view-transition-name: inst-${e.slug}`}
                >
                  {e.university.name}
                </a>
              </th>
              <td class="league__loc">
                {e.university.city ? `${e.university.city}, ` : ""}
                {e.university.country}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    <p class="index__empty" id="empty" hidden>
      No institutions match that search.
    </p>
  </section>

  <script>
    const input = document.querySelector<HTMLInputElement>("#filter");
    const tbody = document.querySelector<HTMLTableSectionElement>("#rows");

    // Institutions sharing a world rank are genuinely tied — the server emits
    // them in a stable (alphabetical) order so the build is reproducible and the
    // no-JS view is sensible, but presenting that order every time would imply a
    // standing that doesn't exist. Shuffle each tied group on load so ties fall
    // out at random and reshuffle on refresh.
    if (tbody) {
      const ordered = Array.from(
        tbody.querySelectorAll<HTMLTableRowElement>(".league__row"),
      );
      const reordered: HTMLTableRowElement[] = [];
      for (let i = 0; i < ordered.length; ) {
        let j = i + 1;
        while (
          j < ordered.length &&
          ordered[j].dataset.rank === ordered[i].dataset.rank
        )
          j += 1;
        const group = ordered.slice(i, j);
        for (let k = group.length - 1; k > 0; k -= 1) {
          const r = Math.floor(Math.random() * (k + 1));
          [group[k], group[r]] = [group[r], group[k]];
        }
        reordered.push(...group);
        i = j;
      }
      for (const row of reordered) tbody.appendChild(row);
    }

    const rows = Array.from(
      document.querySelectorAll<HTMLTableRowElement>(".league__row"),
    );
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".region"),
    );
    const count = document.querySelector<HTMLParagraphElement>("#count");
    const empty = document.querySelector<HTMLParagraphElement>("#empty");
    const total = rows.length;

    let region = "all";

    // Region buttons and the search box compose: a row is shown only when it
    // sits in the active region and its name matches the query.
    function apply() {
      const q = (input?.value ?? "").trim().toLowerCase();
      let shown = 0;
      for (const row of rows) {
        const inRegion = region === "all" || row.dataset.region === region;
        const inSearch = q === "" || (row.dataset.name ?? "").includes(q);
        const match = inRegion && inSearch;
        row.hidden = !match;
        if (match) shown += 1;
      }
      if (empty) empty.hidden = shown !== 0;
      if (count) {
        count.textContent =
          shown === total
            ? `${total} institutions`
            : `${shown} of ${total} institutions`;
      }
    }

    for (const button of buttons) {
      button.addEventListener("click", () => {
        region = button.dataset.region ?? "all";
        for (const b of buttons)
          b.setAttribute(
            "aria-pressed",
            b === button ? "true" : "false",
          );
        apply();
      });
    }

    if (input) input.addEventListener("input", apply);
    apply();
  </script>

  <style>
    .hero {
      padding-block: clamp(2.5rem, 1.5rem + 4vw, 4.5rem) 1.5rem;
    }

    .hero__title {
      margin: 0.4rem 0 0;
      font-size: clamp(2.4rem, 1.4rem + 4.5vw, 4rem);
      max-width: 18ch;
    }

    .hero__lead {
      margin: 1.25rem 0 0;
      max-width: 56ch;
      font-size: 1.15rem;
      color: var(--ink-soft);
    }

    .index {
      padding-bottom: 2rem;
    }

    .index__controls {
      display: flex;
      flex-wrap: wrap;
      align-items: end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 1.25rem;
      padding-top: 1.5rem;
      border-top: 2px solid var(--ink);
    }

    .search {
      display: grid;
      gap: 0.35rem;
      flex: 1 1 20rem;
    }

    .search__label {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
    }

    .search input {
      font: inherit;
      padding: 0.6rem 0.75rem;
      border: 1px solid var(--rule-strong);
      border-radius: var(--radius);
      background: var(--paper);
      color: var(--ink);
    }

    .search input:focus-visible {
      border-color: var(--accent);
      outline-offset: 0;
    }

    .index__count {
      margin: 0;
      font-size: 0.85rem;
      color: var(--ink-faint);
      font-variant-numeric: tabular-nums;
    }

    .index__regions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
    }

    .region {
      font: inherit;
      font-size: 0.85rem;
      padding: 0.4rem 0.85rem;
      color: var(--ink-soft);
      background: var(--paper);
      border: 1px solid var(--rule-strong);
      border-radius: 2rem;
      cursor: pointer;
    }

    .region:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .region:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .region[aria-pressed="true"] {
      color: var(--paper);
      background: var(--ink);
      border-color: var(--ink);
    }

    .league {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.98rem;
    }

    .league caption {
      text-align: left;
    }

    .league thead th {
      text-align: left;
      padding: 0 0.75rem 0.6rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--ink-faint);
      border-bottom: 1px solid var(--rule-strong);
    }

    .league__row {
      position: relative;
      border-bottom: 1px solid var(--rule);
    }

    .league__row:hover {
      background: color-mix(in oklab, var(--accent) 5%, transparent);
    }

    .league__row:hover .league__inst a {
      color: var(--accent);
      text-decoration: underline;
    }

    .league__row td,
    .league__row th {
      padding: 0.85rem 0.75rem;
      vertical-align: baseline;
    }

    .league__rank {
      width: 5.5rem;
      font-size: 1.2rem;
    }

    .league__inst {
      font-weight: 400;
      text-align: left;
    }

    .league__inst a {
      font-family: var(--serif);
      font-size: 1.15rem;
      color: var(--ink);
      text-decoration: none;
    }

    .league__inst a:hover {
      color: var(--accent);
      text-decoration: underline;
    }

    /* The institution link stretches across the whole row so the entire row is
       a single click target. It is now the only link in the row, so there is no
       nested link to raise above it. */
    .league__inst a::after {
      content: "";
      position: absolute;
      inset: 0;
    }

    .league__loc {
      color: var(--ink-soft);
    }

    .index__empty {
      padding: 2rem 0.75rem;
      color: var(--ink-soft);
    }

    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      margin: -1px;
      padding: 0;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    @media (max-width: 34rem) {
      .league__loc-col,
      .league__loc {
        display: none;
      }
    }
  </style>
</Base>
